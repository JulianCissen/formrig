# Copy this file to apps/backend/.env for local development

# PostgreSQL — used by Docker Compose to configure the container AND by the NestJS backend to connect
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=formrig
POSTGRES_PASSWORD=formrig
POSTGRES_DB=formrig

# Form plugin folder (relative to apps/backend/)
PLUGIN_FOLDER=../../plugins/form

# Storage plugin folder (relative to apps/backend/)
FILE_STORAGE_PLUGIN_FOLDER=../../plugins/storage/minio

# MinIO — used by Docker Compose to configure the container AND by the NestJS backend to connect
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=formrig
MINIO_USE_SSL=false
# MinIO web console port
MINIO_CONSOLE_PORT=9001

# Set to 'false' to disable AI features in the app (default: enabled)
AI_FEATURE_ENABLED=true
# Set to 'chat' to open forms in chat mode by default, or 'form' to open in form mode (default: form)
DEFAULT_INTERFACE=form
