{
  "name": "@formrig/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "cross-env PLUGIN_FOLDER=../../plugins/form nest start",
    "start:dev": "cross-env PLUGIN_FOLDER=../../plugins/form nodemon --watch src --watch ../../plugins/form --ext ts,js,json --ignore dist --delay 1 --exec 'nest start'",
    "migration:create": "mikro-orm migration:create",
    "migration:run": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "test": "jest"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@formrig/sdk": "*",
    "@formrig/shared": "*",
    "@mikro-orm/core": "^6.6.7",
    "@mikro-orm/migrations": "^6.6.7",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/postgresql": "^6.6.7",
    "@moduul/core": "^0.1.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@formrig/dev-fixtures": "*",
    "@mikro-orm/cli": "^6.6.7",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^7.0.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.3"
  }
}
