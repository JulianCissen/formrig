# PostgreSQL — configures the container AND the NestJS connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=formrig
POSTGRES_PASSWORD=formrig
POSTGRES_DB=formrig

# Form plugin folder (relative to apps/backend/ for local dev)
PLUGIN_FOLDER=../../plugins/form

# Storage plugin folder (relative to apps/backend/ for local dev)
FILE_STORAGE_PLUGIN_FOLDER=../../plugins/storage/minio

# Antivirus plugin folder (optional — leave blank to disable AV scanning)
AV_PLUGIN_FOLDER=

# MinIO — configures the container AND the NestJS connection
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=formrig
MINIO_USE_SSL=false
# MinIO web console port (Docker Compose only)
MINIO_CONSOLE_PORT=9001

# Quarantine — temporary storage for files that failed AV scanning
QUARANTINE_DIR=./quarantine
# Time-to-live for quarantined files in milliseconds (default: 86400000 = 24 h)
QUARANTINE_TTL_MS=86400000
# Upload pipeline timeout in milliseconds (default: 30000 = 30 s)
FILE_PIPELINE_TIMEOUT_MS=30000

# LLM / AI features — set AI_FEATURE_ENABLED=true to activate the chat interface
LLM_API_KEY=<your-api-key-here>
LLM_MODEL=gpt-4o
# Optional: override base URL for OpenAI-compatible endpoints (e.g. Azure, local LLMs)
LLM_BASE_URL=
AI_FEATURE_ENABLED=false
DEFAULT_INTERFACE=form
